# Local dev environment for nanobot addon testing
# Copy to .env and fill in real values — this file is gitignored.
#
# These env vars override the placeholder values in options.json.

# LLM Provider settings
LLM_PROVIDER=custom
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://your-llm-endpoint/v1
LLM_MODEL=claude-4.5

# Discord settings
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-discord-channel-id-here
DISCORD_ALLOWED_USERS=*
DISCORD_GROUP_POLICY=open

# Timezone
TZ=Europe/Vienna
