# Local dev environment for nanobot addon testing
# Copy to .env and fill in real values — this file is gitignored.
#
# These env vars override the placeholder values in options.json.

# LLM Provider settings
LLM_PROVIDER=custom
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://your-llm-endpoint/v1
LLM_MODEL=claude-4.5

# Discord settings
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-discord-channel-id-here
DISCORD_ALLOWED_USERS=*
DISCORD_GROUP_POLICY=open

# HA MCP Integration (Phase 1)
# Install ha-mcp add-on and paste its URL here
HA_MCP_ENABLED=false
HA_MCP_URL=
HA_ACCESS_TOKEN=
HA_READ_ONLY=true

# OpenAI-compatible API (Phase 2)
# Required for: HA Conversation integration, MQTT inbox
API_ENABLED=false
# Auto-register NanoBot as the HA conversation agent on startup
# Only works under real HA Supervisor (not dev mode)
AUTO_CONVERSATION_AGENT=false

# HA Event Streaming (Phase 3)
HA_EVENTS_ENABLED=false
HA_EVENT_TYPES=state_changed

# MQTT Integration (Phase 4)
# Requires a Mosquitto broker and api_enabled=true
MQTT_ENABLED=false
MQTT_HOST=
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Timezone
TZ=Europe/Vienna
